# Database - lokal fallback (Supabase kullanılıyorsa SUPABASE_DB_URL öncelikli olur)
DB_USER=yzta_user
DB_PASSWORD=yzta_password
DB_NAME=yzta_bootcamp
DB_PORT=5432

# Supabase — yalnızca PostgreSQL olarak kullanılır (bkz. ARCHITECTURE.md).
# ZORUNLU: SUPABASE_DB_URL — paylaşılan ekip veritabanı bağlantısı. Boş bırakılırsa
#   docker-compose yerel postgres container'ına düşer (kendi izole DB'n olur).
#   (Project Settings > Database > Connect > Session pooler; port 5432 kullan,
#   transaction pooler/6543 asyncpg ile prepared-statement çakışması veriyor)
# KULLANILMIYOR: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY —
#   kodda referans edilmez (Supabase Auth/Storage/SDK devrede değil); ileride
#   gerekebilir diye tutuluyor. SUPABASE_DB_PASSWORD yalnızca DB_URL içinde geçer.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-redis-password-for-production

# JWT - Minimum 32 characters!
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-change-me

# APIs
GEMINI_API_KEY=your-gemini-api-key

# Storage (MinIO - S3 uyumlu) — üretilen CV PDF'leri buraya yazılır, Supabase
# Storage KULLANILMAZ (bkz. ARCHITECTURE.md "Dosya Depolama"). Akış:
# CV ajanı → Tectonic PDF → MinIO (bucket=STORAGE_BUCKET, key=cv/{user_id}/{uuid}.pdf)
# → documents.cv_url = STORAGE_PUBLIC_URL/bucket/key. MinIO yereldir; docker-compose
# ile ayağa kalkar, ekstra hesap gerekmez. Varsayılanlar yerel geliştirme için yeterli.
MINIO_ROOT_USER=yzta_minio
MINIO_ROOT_PASSWORD=yzta_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_BUCKET=cv-documents
STORAGE_PUBLIC_URL=http://localhost:9000

# Observability (Sentry - opsiyonel, DSN boşsa devre dışı)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.0

# CORS - Frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# App Settings
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=debug

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
